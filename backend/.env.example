# GROQ API Key for LLM (required)
# Get your API key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# MongoDB Connection String (required)
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=pharmassist_db
MONGO_CHAT_COLLECTION=chat_sessions

# UN Comtrade API Key (required for EXIM agent)
# Get your API key from https://comtradeplus.un.org/
COMTRADE_API_KEY=your_un_comtrade_api_key_here

# Clerk Authentication (required)
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# OpenAI API Key (optional - for enhanced features)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
