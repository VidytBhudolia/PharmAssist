# Environment Variables Setup
#
# This project requires .env files in BOTH backend and frontend folders:
#
# 1. backend/.env - For backend API keys and configuration
# 2. frontend/.env - For frontend Vite environment variables
#
# This file is documentation only and is NOT loaded at runtime.
# See docs/ENV_SETUP_REFERENCE.md for a complete, safe template.

# ===========================================
# backend/.env (create this file in backend/)
# ===========================================
# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=pharmassist_db
MONGO_CHAT_COLLECTION=chat_sessions

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# API Keys
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
COMTRADE_API_KEY=your_un_comtrade_api_key_here

# Other configurations
PYTHONUNBUFFERED=1

# ===========================================
# frontend/.env (create this file in frontend/)
# ===========================================
# Clerk Authentication (Publishable Key)
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Backend API URL
VITE_API_URL=http://localhost:8000
